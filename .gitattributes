# Linguistic detection — não inflar estatísticas de linguagem com assets binários
logos/** linguist-vendored
fonts/** linguist-vendored
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary

# Garantir LF em arquivos texto
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
LICENSE text eol=lf
